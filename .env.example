# ── Application ──────────────────────────────────────────────────────────────
# Em produção (VM/Docker): usa --env-file com um ficheiro fora do git (ex.: chmod 600 na VM).
# In production: use --env-file pointing at a host-only file; never commit real values.
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Force JSON log format (default: JSON when DEBUG=false, console when DEBUG=true)
# LOG_FORMAT=json

# Enable Flask debug mode (never set to true in production)
DEBUG=false

# Flask secret key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# ── Database ─────────────────────────────────────────────────────────────────
# Development: SQLite file path (directory created if missing). Default: data/app.db
SQLITE_PATH=data/app.db

# Production: set to use another adapter (e.g. PostgreSQL). When set (and not sqlite), app uses production adapter.
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Rate limiting (items API): limits are per-route; disable in tests via TESTING=true
# RATELIMIT_ENABLED=true

# ── External APIs (add as needed) ──────────────────────────────────────────────
# API_KEY=your-api-key-here
